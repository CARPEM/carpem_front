  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "d3": "^7.9.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^2.14.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/fhir": "^0.0.41",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
